# Copilot Proxy Server - Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 3001)
PORT=3001

# CLI Mode: Set to "remote" to connect to external CLI, or "local" for SDK-managed CLI
# CLI_MODE=local

# Remote CLI URL (only used when CLI_MODE=remote)
# COPILOT_CLI_URL=localhost:4321

# ADO_MCP_AUTH_TOKEN: Azure DevOps Personal Access Token for MCP authentication
ADO_MCP_AUTH_TOKEN=your_ado_mcp_auth_token_here
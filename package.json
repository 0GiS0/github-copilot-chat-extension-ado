{
  "name": "github-copilot-chat-extension-ado",
  "version": "1.0.0",
  "description": "GitHub Copilot Chat integration for Azure DevOps - An extension that brings AI-powered assistance directly into your Azure DevOps workflow",
  "keywords": [
    "azure-devops",
    "azure-devops-extension",
    "github-copilot",
    "copilot",
    "ai",
    "chat",
    "productivity",
    "devops"
  ],
  "license": "MIT",
  "author": {
    "name": "Gisela Torres",
    "url": "https://github.com/0GiS0"
  },
  "homepage": "https://github.com/0GiS0/github-copilot-chat-extension-ado#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0GiS0/github-copilot-chat-extension-ado.git"
  },
  "bugs": {
    "url": "https://github.com/0GiS0/github-copilot-chat-extension-ado/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "compile": "npm run clean && webpack --mode production",
    "compile:dev": "npm run clean && webpack --mode development",
    "build": "npm run compile",
    "build:dev": "npm run compile:dev && npm run postbuild",
    "postbuild": "npm run package-extension -- --rev-version",
    "package-extension": "tfx extension create --manifest-globs azure-devops-extension.json src/Hub/*.json",
    "publish-extension": "tfx extension publish --manifest-globs azure-devops-extension.json src/Hub/*.json",
    "publish-extension:dev": "tfx extension publish --manifest-globs azure-devops-extension-dev.json src/Hub/*.json",
    "start:dev": "webpack-dev-server --mode development",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "server:start": "cd server && npm start",
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"bgBlue,bgGreen\" \"npm run server:dev\" \"npm run start:dev\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "prepare": "npm run compile"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.266.0",
    "azure-devops-extension-sdk": "^4.2.0",
    "azure-devops-ui": "^2.167.63",
    "react": "~16.13.1",
    "react-dom": "~16.13.1"
  },
  "devDependencies": {
    "@babel/core": "^7.21.8",
    "@testing-library/jest-dom": "^5.11.0",
    "@testing-library/react": "^10.4.4",
    "@types/jest": "^26.0.3",
    "@types/react": "~16.8.2",
    "@types/react-dom": "~16.8.0",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.3",
    "jest": "^26.1.0",
    "jest-junit-reporter": "^1.1.0",
    "rimraf": "^6.1.2",
    "sass": "^1.62.1",
    "sass-loader": "^16.0.6",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.23.1",
    "ts-jest": "^26.1.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.23.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.0.4"
  },
  "jest": {
    "transform": {
      "^.+\\.(js|ts|tsx|jsx)$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|azure-devops-ui|azure-devops-extension-sdk)/)"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/src/__mocks__/fileMock.js",
      "\\.(css|less|scss)$": "<rootDir>/src/__mocks__/styleMock.js"
    },
    "preset": "ts-jest/presets/js-with-babel",
    "testResultsProcessor": "./node_modules/jest-junit-reporter",
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "html",
      "cobertura"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "overrides": {
    "tfx-cli": {
      "xml2js": "0.5.0"
    }
  }
}
